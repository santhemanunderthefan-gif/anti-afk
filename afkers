-- White Screen + 10 FPS Cap + Anti-AFK
repeat task.wait() until game:IsLoaded()

-- ============ FPS CAP USING SETFPSCAP ============
setfpscap(10)
print("✅ FPS cap set to 10 using setfpscap")

local runService = game:GetService("RunService")
local lighting = game:GetService("Lighting")
local workspace = game:GetService("Workspace")
local localPlayer = game:GetService("Players").LocalPlayer
local virtualUser = game:GetService("VirtualUser")

-- ============ ANTI-AFK ============
print("🔄 Starting Anti-AFK...")

local function antiAFK()
    -- Method 1: Bypass idle (for executors that support it)
    pcall(function()
        game:GetService("Players").LocalPlayer.Idled:Connect(function()
            virtualUser:CaptureController()
            virtualUser:ClickButton2(Vector2.new())
        end)
    end)
    
    -- Method 2: Simulate mouse movement every 30 seconds
    local vim = game:GetService("VirtualInputManager")
    task.spawn(function()
        while true do
            task.wait(30)
            pcall(function()
                vim:SendMouseMoveEvent(100, 100, 0, game)
                task.wait(0.1)
                vim:SendMouseMoveEvent(200, 200, 0, game)
            end)
        end
    end)
    
    -- Method 3: Small movement every 2 minutes
    task.spawn(function()
        while true do
            task.wait(120)
            pcall(function()
                local char = localPlayer.Character
                if char and char.Humanoid then
                    char.Humanoid:Move(Vector3.new(1, 0, 0))
                    task.wait(0.5)
                    char.Humanoid:Move(Vector3.new(-1, 0, 0))
                end
            end)
        end
    end)
end

antiAFK()
print("✅ Anti-AFK active")

-- ============ WHITE SCREEN ============
print("🌕 Enabling white screen mode...")

-- Create white overlay GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "WhiteScreenOverlay"
screenGui.IgnoreGuiInset = true
screenGui.ResetOnSpawn = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

local whiteFrame = Instance.new("Frame")
whiteFrame.Size = UDim2.new(1, 0, 1, 0)
whiteFrame.Position = UDim2.new(0, 0, 0, 0)
whiteFrame.BackgroundColor3 = Color3.new(1, 1, 1)
whiteFrame.BackgroundTransparency = 0
whiteFrame.BorderSizePixel = 0
whiteFrame.ZIndex = 999
whiteFrame.Parent = screenGui

pcall(function()
    screenGui.Parent = game:GetService("CoreGui")
end)

-- Make game world white
pcall(function()
    lighting.Ambient = Color3.new(1, 1, 1)
    lighting.Brightness = 2
    lighting.ClockTime = 12
    lighting.FogColor = Color3.new(1, 1, 1)
    lighting.FogEnd = 0.1
    lighting.FogStart = 0
    lighting.GlobalShadows = false
    lighting.OutdoorAmbient = Color3.new(1, 1, 1)
end)

-- Hide all parts
pcall(function()
    for _, child in ipairs(workspace:GetChildren()) do
        if child:IsA("BasePart") and child ~= workspace.CurrentCamera then
            child.Transparency = 1
        elseif child:IsA("Model") and child ~= localPlayer.Character then
            for _, part in ipairs(child:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Transparency = 1
                end
            end
        end
    end
end)

print("✅ White screen mode enabled")
print("========================================")
print("🎯 White Screen + 10 FPS Cap + Anti-AFK ACTIVE")
print("========================================")

-- Keep script running
while task.wait(60) do
    print("💓 Still running - Anti-AFK active")
end
